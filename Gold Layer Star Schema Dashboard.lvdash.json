{
  "datasets": [
    {
      "name": "gold_sales_metrics",
      "displayName": "Gold Sales Metrics",
      "config": {
        "version": 1.0,
        "source": "SELECT \n  f.sales_key,\n  f.order_number,\n  f.customer_key,\n  f.product_key,\n  f.order_date_key,\n  f.sales_amount,\n  f.quantity,\n  f.unit_price,\n  c.country,\n  c.gender,\n  c.marital_status,\n  p.category,\n  p.subcategory,\n  p.product_name,\n  p.product_line,\n  d.date,\n  d.year,\n  d.quarter,\n  d.month,\n  d.month_name\nFROM bigdata_catalog.gold.fact_sales f JOIN bigdata_catalog.gold.dim_customers c ON f.customer_key = c.customer_key JOIN bigdata_catalog.gold.dim_products p ON f.product_key = p.product_key JOIN bigdata_catalog.gold.dim_date d ON f.order_date_key = d.date_key\n",
        "dimensions": [
          {
            "name": "order_number",
            "expr": "order_number"
          },
          {
            "name": "country",
            "expr": "country"
          },
          {
            "name": "gender",
            "expr": "gender"
          },
          {
            "name": "marital_status",
            "expr": "marital_status"
          },
          {
            "name": "category",
            "expr": "category"
          },
          {
            "name": "subcategory",
            "expr": "subcategory"
          },
          {
            "name": "product_name",
            "expr": "product_name"
          },
          {
            "name": "product_line",
            "expr": "product_line"
          },
          {
            "name": "year",
            "expr": "year"
          },
          {
            "name": "quarter",
            "expr": "quarter"
          },
          {
            "name": "month",
            "expr": "month"
          },
          {
            "name": "month_name",
            "expr": "month_name"
          },
          {
            "name": "date",
            "expr": "date"
          }
        ],
        "measures": [
          {
            "name": "total_revenue",
            "expr": "SUM(sales_amount)"
          },
          {
            "name": "total_quantity",
            "expr": "SUM(quantity)"
          },
          {
            "name": "order_count",
            "expr": "COUNT(DISTINCT order_number)"
          },
          {
            "name": "avg_order_value",
            "expr": "SUM(sales_amount) / COUNT(DISTINCT order_number)"
          },
          {
            "name": "customer_count",
            "expr": "COUNT(DISTINCT customer_key)"
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "c87ea425",
      "displayName": "Page 1",
      "layout": [
        {
          "widget": {
