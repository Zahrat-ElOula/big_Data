{
  "datasets": [
    {
      "name": "bronze_ingestion_timestamp",
      "displayName": "Bronze Latest Ingestion",
      "queryLines": [
        "SELECT\n",
        "  MAX(\n",
        "    GREATEST(\n",
        "      (\n",
        "        SELECT\n",
        "          MAX(_ingestion_ts)\n",
        "        FROM\n",
        "          bigdata_catalog.bronze.crm_customers\n",
        "      ),\n",
        "      (\n",
        "        SELECT\n",
        "          MAX(_ingestion_ts)\n",
        "        FROM\n",
        "          bigdata_catalog.bronze.crm_products\n",
        "      ),\n",
        "      (\n",
        "        SELECT\n",
        "          MAX(_ingestion_ts)\n",
        "        FROM\n",
        "          bigdata_catalog.bronze.crm_sales\n",
        "      ),\n",
        "      (\n",
        "        SELECT\n",
        "          MAX(_ingestion_ts)\n",
        "        FROM\n",
        "          bigdata_catalog.bronze.erp_customer_demographics\n",
        "      ),\n",
        "      (\n",
        "        SELECT\n",
        "          MAX(_ingestion_ts)\n",
        "        FROM\n",
        "          bigdata_catalog.bronze.erp_customer_location\n",
        "      ),\n",
        "      (\n",
        "        SELECT\n",
        "          MAX(_ingestion_ts)\n",
        "        FROM\n",
        "          bigdata_catalog.bronze.erp_product_category\n",
        "      )\n",
        "    )\n",
        "  ) as latest_ingestion"
      ]
    },
    {
      "name": "bronze_sales_by_product",
      "displayName": "Bronze Sales by Product Line",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN p.prd_line IS NOT NULL THEN p.prd_line\n",
        "    WHEN s.sls_prd_key LIKE 'BK-M%' THEN 'Mountain Bikes'\n",
        "    WHEN s.sls_prd_key LIKE 'BK-R%' THEN 'Road Bikes'\n",
        "    WHEN s.sls_prd_key LIKE 'BK-T%' THEN 'Touring Bikes'\n",
        "    ELSE 'Unknown'\n",
        "  END as product_line,\n",
        "  COUNT(*) as sales_count,\n",
        "  ROUND(SUM(s.sls_price), 2) as total_revenue\n",
        "FROM\n",
        "  bigdata_catalog.bronze.crm_sales s\n",
        "    LEFT JOIN bigdata_catalog.bronze.crm_products p\n",
        "      ON s.sls_prd_key = p.prd_key\n",
        "WHERE\n",
        "  s.sls_order_dt != 0\n",
        "GROUP BY\n",
        "  product_line\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ]
    },
    {
      "name": "bronze_customers_by_country",
      "displayName": "Bronze Customers by Country",
      "queryLines": [
        "SELECT\n",
        "  l.CNTRY as country,\n",
        "  COUNT(DISTINCT c.cst_id) as customer_count\n",
        "FROM\n",
        "  bigdata_catalog.bronze.crm_customers c\n",
        "    INNER JOIN bigdata_catalog.bronze.erp_customer_location l\n",
        "      ON c.cst_id = l.CID\n",
        "GROUP BY\n",
        "  l.CNTRY\n",
        "ORDER BY\n",
        "  customer_count DESC"
      ]
    },
    {
      "name": "bronze_table_counts",
      "displayName": "Bronze Table Counts",
      "queryLines": [
        "SELECT\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      bigdata_catalog.bronze.crm_customers\n",
        "  ) as crm_customers_count,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      bigdata_catalog.bronze.crm_products\n",
        "  ) as crm_products_count,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      bigdata_catalog.bronze.crm_sales\n",
        "  ) as crm_sales_count,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      bigdata_catalog.bronze.erp_customer_demographics\n",
        "  ) as erp_demographics_count,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      bigdata_catalog.bronze.erp_customer_location\n",
        "  ) as erp_location_count,\n",
        "  (\n",
        "    SELECT\n",
        "      COUNT(*)\n",
        "    FROM\n",
        "      bigdata_catalog.bronze.erp_product_category\n",
        "  ) as erp_category_count"
      ]
    },
    {
      "name": "bronze_data_quality",
      "displayName": "Bronze Data Quality Issues",
      "queryLines": [
        "SELECT\n",
        "  'Invalid Dates' as issue_type,\n",
        "  COUNT(*) as issue_count,\n",
        "  'crm_sales table has order_dt=0' as description\n",
        "FROM\n",
        "  bigdata_catalog.bronze.crm_sales\n",
        "WHERE\n",
        "  sls_order_dt = 0\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Orphaned Customers' as issue_type,\n",
        "  COUNT(*) as issue_count,\n",
        "  'CRM customers without ERP demographics' as description\n",
        "FROM\n",
        "  bigdata_catalog.bronze.crm_customers c\n",
        "    LEFT JOIN bigdata_catalog.bronze.erp_customer_demographics d\n",
        "      ON c.cst_id = d.CID\n",
        "WHERE\n",
        "  d.CID IS NULL\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Missing Product Categories' as issue_type,\n",
        "  COUNT(*) as issue_count,\n",
        "  'Products without category assignment' as description\n",
        "FROM\n",
        "  bigdata_catalog.bronze.crm_products\n",
        "WHERE\n",
        "  prd_line IS NULL\n",
        "  OR TRIM(prd_line) = ''"
      ]
    }
  ],
